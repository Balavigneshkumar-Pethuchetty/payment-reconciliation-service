# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=payment_reconciliation

# Used by the API when running outside Docker (docker-compose builds its own URL from the vars above)
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/payment_reconciliation

# ── Service ───────────────────────────────────────────────────────────────────
SERVICE_BASE_URL=https://pay.yourdomain.com

# ── UPI ───────────────────────────────────────────────────────────────────────
UPI_VPA=yoursociety@upi
UPI_DISPLAY_NAME=My Society

# ── Hyperswitch ───────────────────────────────────────────────────────────────
HYPERSWITCH_BASE_URL=http://localhost:8080
HYPERSWITCH_API_KEY=your_hyperswitch_api_key

# ── Ollama ────────────────────────────────────────────────────────────────────
# When running outside Docker use http://localhost:11434
# docker-compose overrides this to http://ollama:11434 (internal service name)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llava
OLLAMA_VISION_MODEL=llava

# ── Security ──────────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-long-random-secret-key

# ── Admin account (created automatically on first startup) ────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# ── pgAdmin ───────────────────────────────────────────────────────────────────
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=admin123

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=https://yourdomain.com,http://localhost:3000,http://localhost:5173,http://localhost:8080

# ── Keycloak (optional — service works without it) ────────────────────────────
KEYCLOAK_URL=https://auth.yourdomain.com
KEYCLOAK_REALM=your-realm
KEYCLOAK_AUDIENCE=payment-service
KEYCLOAK_LOGIN_CLIENT_ID=your-public-client

# ── Google OAuth (for Ollama Chat login via Keycloak) ─────────────────────────
# 1. Create an OAuth 2.0 client at console.cloud.google.com → APIs & Services → Credentials
# 2. Authorized redirect URI: ${KEYCLOAK_URL}/realms/ollama-chat/broker/google/endpoint
# 3. Then run: bash scripts/setup-ollama-realm.sh
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-secret

# ── Anthropic Claude API (optional) ───────────────────────────────────────────
# When set, the Ollama Chat UI routes all requests to Claude instead of local Ollama.
# Ollama is kept running as a fallback.
# Get your key from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
