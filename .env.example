DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/payment_reconciliation

# Public URL of this service
SERVICE_BASE_URL=https://pay.yourdomain.com

# UPI Configuration
UPI_VPA=yoursociety@upi
UPI_DISPLAY_NAME=My Society

# Hyperswitch (self-hosted or cloud)
HYPERSWITCH_BASE_URL=http://localhost:8080
HYPERSWITCH_API_KEY=your_hyperswitch_api_key

# Ollama (local LLM for SMS/Email/Image parsing)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
OLLAMA_VISION_MODEL=llava

# Security — change this to a long random string in production!
SECRET_KEY=change-this-to-a-random-secret-key

# Default local admin account (created automatically on first startup)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-please

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=https://yourdomain.com,http://localhost:3000

# Keycloak — JWKS-only validation (optional, service works without it)
KEYCLOAK_URL=https://auth.yourdomain.com
KEYCLOAK_REALM=your-realm
KEYCLOAK_AUDIENCE=payment-service
KEYCLOAK_LOGIN_CLIENT_ID=your-public-client
